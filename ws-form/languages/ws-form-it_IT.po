msgstr "Sposta nel cestino o elimina definitivamente un modulo tramite ID."

#: includes/config/class-ws-form-config-ability.php:808
msgid "Restore form"
msgstr "Ripristina modulo"

#: includes/config/class-ws-form-config-ability.php:809
